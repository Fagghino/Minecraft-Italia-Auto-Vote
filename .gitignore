# ========================================
# .gitignore - Minecraft-Italia Auto-Vote
# ========================================

# Sicurezza & Credenziali
.env
.env.*
!.env.example
cookies.json

# Dipendenze Node.js
node_modules/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Build & Test
dist/
build/
out/
coverage/
.nyc_output/
*.tsbuildinfo

# Log & Debug
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Cache & Temporanei
.npm/
.eslintcache
.stylelintcache
.prettiercache
tmp/
temp/

# IDE & Editor
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.iml

# Sistema Operativo
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
*~

# Specifiche del progetto
api/
Docs/*
!CHANGELOG.md