# ================================================
# FILE DI CONFIGURAZIONE DI ESEMPIO (.env.example)
# ================================================
#
# ISTRUZIONI:
# 1. Copia questo file e rinominalo in ".env"
# 2. Inserisci i tuoi dati al posto degli esempi
# 3. NON CONDIVIDERE MAI IL FILE .env CON NESSUNO
#
# ================================================

# ---- CREDENZIALI DI ACCESSO (OBBLIGATORI) ----
EMAIL=la-tua-email@esempio.it
PASSWORD=la-tua-password-segreta

# URL della pagina del server da votare
SERVER_URL=https://minecraft-italia.net/lista/server/iltuoserver

# ---- IMPOSTAZIONI VISUALIZZAZIONE ----
# Modalità headless (true = nascosto in background, false = visibile per debug)
HEADLESS=true

# ---- NOMI MANUALI (OPZIONALI ma CONSIGLIATI) ----
# Rimuovi il cancelletto (#) per abilitarli. Inserirli aiuta le API a non
# confondersi con scritte sul sito web, rendendo i pre-check più precisi.
#PLAYER_NAME=TuoNomeInGioco
#SERVER_NAME=NomeDelTuoServer

# ---- OPZIONI DELLE API ----
# true = controlla prima se hai già votato oggi per saltare il procedimento
USE_API_PRECHECK=true

# Impostazioni di timeout e riprova API (Valori di default, non serve modificarli)
API_RETRIES=3
API_BACKOFF_BASE_MS=500
API_TIMEOUT_MS=7000
API_MIN_INTERVAL_MS=200
API_CACHE_TTL_SEC=60